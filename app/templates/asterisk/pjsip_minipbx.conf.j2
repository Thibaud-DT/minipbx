; Generated by MiniPBX. Do not edit manually.

[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:{{ sip_port }}
{% if external_address %}
external_signaling_address={{ external_address }}
external_media_address={{ external_address }}
local_net={{ local_net }}
{% endif %}

{% for extension in extensions if extension.enabled %}
[{{ extension.sip_username }}]
type=endpoint
context=minipbx-internal
disallow=all
allow=ulaw,alaw
auth={{ extension.sip_username }}-auth
aors={{ extension.sip_username }}
direct_media=no
force_rport=yes
rewrite_contact=yes
rtp_symmetric=yes

[{{ extension.sip_username }}-auth]
type=auth
auth_type=userpass
username={{ extension.sip_username }}
password={{ extension.sip_secret }}

[{{ extension.sip_username }}]
type=aor
max_contacts=1
remove_existing=yes
qualify_frequency=60

{% endfor %}
{% if trunk %}
[trunk-main]
type=endpoint
transport=transport-udp
context=minipbx-inbound
disallow=all
allow=ulaw,alaw
outbound_auth=trunk-main-auth
aors=trunk-main
from_user={{ trunk.from_user or trunk.username }}
from_domain={{ trunk.from_domain or trunk.host }}
direct_media=no
force_rport=yes
rewrite_contact=yes
rtp_symmetric=yes

[trunk-main-auth]
type=auth
auth_type=userpass
username={{ trunk.username }}
password={{ trunk.password_secret }}

[trunk-main]
type=aor
contact=sip:{{ trunk.host }}

[trunk-main-identify]
type=identify
endpoint=trunk-main
{% for match in trunk_inbound_matches %}
match={{ match }}
{% endfor %}

{% if trunk.host not in ["127.0.0", "127.0.0.1", "localhost"] %}
[trunk-main-registration]
type=registration
outbound_auth=trunk-main-auth
server_uri=sip:{{ trunk.host }}
client_uri=sip:{{ trunk.username }}@{{ trunk.host }}
retry_interval=60
{% endif %}
{% endif %}
