[minipbx-inbound]
{% if inbound_routes %}
{% for entry in inbound_routes if entry.is_default %}
exten => s,1,Goto(minipbx-inbound-route-{{ entry.route.id }},s,1)
{% endfor %}
{% if not inbound_routes | selectattr("is_default") | list %}
exten => s,1,Hangup()
{% endif %}
{% for entry in inbound_routes if entry.route.did_number %}
exten => {{ entry.route.did_number }},1,Goto(minipbx-inbound-route-{{ entry.route.id }},s,1)
{% endfor %}
{% else %}
exten => s,1,NoOp(Inbound call)
{% set first_inbound = extensions | selectattr("inbound_enabled") | list | first %}
{% if first_inbound %}
 same => n,Dial(PJSIP/{{ first_inbound.sip_username }},20)
{% if first_inbound.voicemail_enabled %}
 same => n,Goto(minipbx-voicemail,{{ first_inbound.number }},1)
{% endif %}
{% else %}
 same => n,Playback(feature-not-avail-line)
{% endif %}
 same => n,Hangup()
{% endif %}

{% for entry in inbound_routes %}
[minipbx-inbound-route-{{ entry.route.id }}]
exten => s,1,NoOp(Inbound route {{ entry.route.name }})
{% if entry.route.use_business_hours %}
{% for holiday in entry.holiday_dates %}
 same => n,GotoIfTime(*,*,{{ holiday.day }},{{ holiday.month }}?closed)
{% endfor %}
 same => n,GotoIfTime({{ entry.route.business_open_time }}-{{ entry.route.business_close_time }},{{ entry.business_days }},*,*?open)
 same => n,Goto(closed)
 same => n(open),{{ goto_destination(entry.route.open_destination_type, entry.route.open_destination_target) }}
 same => n,Hangup()
 same => n(closed),{{ goto_destination(entry.route.closed_destination_type, entry.route.closed_destination_target) }}
 same => n,Hangup()
{% else %}
 same => n,{{ goto_destination(entry.route.open_destination_type, entry.route.open_destination_target) }}
 same => n,Hangup()
{% endif %}

{% endfor %}

[minipbx-voicemail]
{% for extension in extensions if extension.enabled and extension.voicemail_enabled %}
exten => {{ extension.number }},1,NoOp(Voicemail {{ extension.number }})
{% if extension.voicemail_greeting_mode == "recording" and extension.voicemail_greeting_playback_path %}
 same => n,Background({{ extension.voicemail_greeting_playback_path }})
 same => n,VoiceMail({{ extension.number }}@default,s)
{% elif extension.voicemail_greeting_mode == "tts" and extension.voicemail_greeting_text and tts_backend == "flite" %}
 same => n,TryExec(Flite("{{ extension.voicemail_greeting_text | replace('"', '') | replace('\n', ' ') }}"))
 same => n,VoiceMail({{ extension.number }}@default,s)
{% elif extension.voicemail_greeting_mode == "tts" and extension.voicemail_greeting_text %}
 same => n,NoOp(TTS disabled: {{ extension.voicemail_greeting_text | replace('\n', ' ') }})
 same => n,VoiceMail({{ extension.number }}@default,u)
{% else %}
 same => n,VoiceMail({{ extension.number }}@default,u)
{% endif %}
 same => n,Hangup()

{% endfor %}
exten => _X.,1,Hangup()

{% for menu in ivr_menus %}
[minipbx-ivr-{{ menu.id }}]
exten => s,1,NoOp(IVR {{ menu.name }})
 same => n,Answer()
 same => n,Set(TIMEOUT(digit)=5)
 same => n,Set(TIMEOUT(response)={{ menu.timeout_seconds }})
{% if menu.prompt_mode == "recording" and menu.playback_path %}
 same => n,Background({{ menu.playback_path }})
{% elif menu.prompt_mode == "tts" and menu.prompt_text and tts_backend == "flite" %}
 same => n,TryExec(Flite("{{ menu.prompt_text | replace('"', '') | replace('\n', ' ') }}"))
{% elif menu.prompt_mode == "tts" and menu.prompt_text %}
 same => n,NoOp(TTS disabled: {{ menu.prompt_text | replace('\n', ' ') }})
 same => n,Playback(beep)
{% else %}
 same => n,Playback(beep)
{% endif %}
 same => n,WaitExten({{ menu.timeout_seconds }})
{% for option in menu.options %}
exten => {{ option.digit }},1,{{ goto_destination(option.destination_type, option.destination_target) }}
 same => n,Hangup()
{% endfor %}
exten => i,1,Goto(s,1)
exten => t,1,{{ goto_destination(menu.fallback_type, menu.fallback_target) }}
 same => n,Hangup()

{% endfor %}
