{% macro goto_destination(destination_type, destination_target) -%}
{% if destination_type == "extension" and destination_target -%}
Goto(minipbx-internal,{{ destination_target }},1)
{%- elif destination_type == "ring_group" and destination_target -%}
Goto(minipbx-internal,{{ destination_target }},1)
{%- elif destination_type == "ivr" and destination_target -%}
Goto(minipbx-internal,{{ destination_target }},1)
{%- elif destination_type == "voicemail" and destination_target -%}
Goto(minipbx-voicemail,{{ destination_target }},1)
{%- else -%}
Hangup()
{%- endif %}
{%- endmacro %}

[minipbx-internal]
{% for extension in extensions if extension.enabled %}
exten => {{ extension.number }},1,Dial(PJSIP/{{ extension.sip_username }},20)
 same => n,{% if extension.voicemail_enabled %}Goto(minipbx-voicemail,{{ extension.number }},1){% else %}Hangup(){% endif %}

{% endfor %}
{% for group in ring_groups %}
{% set active_members = group.members | selectattr("extension.enabled") | list %}
exten => {{ group.number }},1,NoOp(Ring group {{ group.name }})
{% if active_members %}
 same => n,Dial({% for member in active_members %}PJSIP/{{ member.extension.sip_username }}{% if not loop.last %}&{% endif %}{% endfor %},{{ group.timeout_seconds }})
{% if group.fallback_type == "extension" and group.fallback_target %}
 same => n,Goto(minipbx-internal,{{ group.fallback_target }},1)
{% elif group.fallback_type == "voicemail" and group.fallback_target %}
 same => n,Goto(minipbx-voicemail,{{ group.fallback_target }},1)
{% else %}
 same => n,Hangup()
{% endif %}
{% else %}
 same => n,Hangup()
{% endif %}

{% endfor %}
{% for menu in ivr_menus %}
exten => {{ menu.number }},1,Goto(minipbx-ivr-{{ menu.id }},s,1)

{% endfor %}
exten => *97,1,VoiceMailMain(${CALLERID(num)}@default)
 same => n,Hangup()

