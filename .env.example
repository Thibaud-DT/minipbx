MINIPBX_WEB_HOST=0.0.0.0
MINIPBX_WEB_PORT=8080
MINIPBX_SECRET_KEY=change-me-generate-with-install-sh
MINIPBX_SESSION_HTTPS_ONLY=false
MINIPBX_SESSION_MAX_AGE_SECONDS=28800
MINIPBX_CSRF_ENABLED=true
MINIPBX_MIGRATIONS_ENABLED=true
MINIPBX_RUNTIME_USER=asterisk

MINIPBX_TIMEZONE=Europe/Paris
MINIPBX_COUNTRY=FR
MINIPBX_DATA_DIR=/var/lib/minipbx
MINIPBX_GENERATED_CONFIG_DIR=/var/lib/minipbx/generated
MINIPBX_PROMPT_DIR=/var/lib/minipbx/prompts
MINIPBX_BACKUP_DIR=/var/lib/minipbx/backups
MINIPBX_IMPORT_DIR=/var/lib/minipbx/imports
MINIPBX_CDR_CSV_PATH=/var/log/asterisk/cdr-csv/Master.csv
MINIPBX_VOICEMAIL_SPOOL_DIR=/var/spool/asterisk/voicemail/default
MINIPBX_ASTERISK_CONFIG_DIR=/etc/asterisk
MINIPBX_ASTERISK_RELOAD_COMMAND=asterisk -C /etc/asterisk/asterisk.conf -rx 'core reload'
MINIPBX_ASTERISK_STATUS_COMMAND=asterisk -C /etc/asterisk/asterisk.conf -rx 'core show uptime'
MINIPBX_ASTERISK_APPLY_ENABLED=true
MINIPBX_ADMIN_USERNAME=admin
MINIPBX_AMI_ENABLED=true
MINIPBX_AMI_BIND_ADDRESS=127.0.0.1
MINIPBX_AMI_PORT=5038
MINIPBX_AMI_USERNAME=minipbx
MINIPBX_AMI_PASSWORD=change-me-generate-with-install-sh
# none par defaut. Mettre flite uniquement si le module Asterisk app_flite est installe.
MINIPBX_TTS_BACKEND=none

ASTERISK_SIP_PORT=5060
ASTERISK_RTP_START=10000
ASTERISK_RTP_END=10100
# En mode bridge Docker Desktop, mettre ASTERISK_EXTERNAL_ADDRESS sur l'adresse
# LAN de la machine Docker utilisee par les softphones, par exemple 192.168.1.42.
# ASTERISK_LOCAL_NET doit rester le reseau interne Docker, pas le LAN.
ASTERISK_EXTERNAL_ADDRESS=
ASTERISK_LOCAL_NET=172.18.0.0/16
